@model DreamDayWeddingPlanningManagementSystem.Models.LoginViewModel

@{
    ViewData["Title"] = "Admin Login";
    Layout = "_Layout";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="card w-50 shadow-sm">
        <div class="card-header bg-dark text-white p-3 rounded-top">
            <h2 class="card-title mb-0">Admin Login</h2>
        </div>
        <div class="card-body p-4">
            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label for="adminEmail" class="form-label">Email Address</label>
                    <input id="adminEmail" name="Email" asp-for="Email" class="form-control" placeholder="admin@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label for="adminPassword" class="form-label">Password</label>
                    <input id="adminPassword" name="Password" asp-for="Password" class="form-control" type="password" placeholder="Enter your password" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-dark">Login</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
