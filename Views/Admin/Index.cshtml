@model DreamDayWeddingPlanningManagementSystem.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_Layout";
}

<div class="container py-5">
    <h2 class="fw-bold mb-4">🛠️ Admin Dashboard</h2>

    <div class="row g-4">
        <!-- Users Card -->
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h4 class="fw-semibold mb-3">👤 Registered Users</h4>
                    @if (Model.Users != null && Model.Users.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var user in Model.Users)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="fw-medium">@user.FullName</span><br />
                                        <small class="text-muted">@user.Email</small>
                                    </div>
                                    <span class="badge bg-primary">User</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">No users found.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Vendors Card -->
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h4 class="fw-semibold mb-3">🏢 Registered Vendors</h4>
                    @if (Model.Vendors != null && Model.Vendors.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var vendor in Model.Vendors)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="fw-medium">@vendor.Name</span><br />
                                        <small class="text-muted">@vendor.Email</small>
                                    </div>
                                    <span class="badge bg-secondary">Vendor</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">No vendors found.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
