@model IEnumerable<DreamDayWeddingPlanningManagementSystem.Models.ChecklistItem>

@{
    ViewData["Title"] = "Wedding Checklist";
    Layout = "_Layout";

    var totalTasks = Model.Count();
    var completedTasks = Model.Count(i => i.IsCompleted);
    var progress = totalTasks > 0 ? (int)((double)completedTasks / totalTasks * 100) : 0;
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Wedding Checklist</h2>
        <a class="btn btn-dark rounded-pill" href="@Url.Action("Create", "Checklist")">+ Add New Task</a>
    </div>

    <!-- Progress Bar -->
    <div class="mb-4">
        <label class="form-label fw-semibold">Progress</label>
        <div class="progress rounded-pill" style="height: 20px;">
            <div class="progress-bar bg-success" role="progressbar" style="width: @progress%" aria-valuenow="@progress" aria-valuemin="0" aria-valuemax="100">
                @progress%
            </div>
        </div>
    </div>

    <!-- Checklist Table -->
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Task</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-medium">@item.Task</td>
                        <td>
                            @if (item.IsCompleted)
                            {
                                <span class="badge bg-success">Completed ✅</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pending ⏳</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
