@model DreamDayWeddingPlanningManagementSystem.Models.Vendor

@{
    ViewData["Title"] = "Vendor Registration";
    Layout = "_Layout";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <div class="card registration-card shadow-lg border-0 rounded-4 p-0" style="width: 100%; max-width: 550px;">
        <!-- Header -->
        <div class="registration-header bg-dark text-white text-center py-4 rounded-top-4">
            <h2 class="fw-bold mb-0">Vendor Registration</h2>
            <p class="text-light small mb-0">Join our platform to offer your wedding services</p>
        </div>

        <!-- Form Body -->
        <div class="registration-body p-4 bg-white">
            <form asp-action="Register" method="post">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold">Business Name</label>
                    <input asp-for="Name" class="form-control rounded-3" placeholder="Your business name" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                    <input asp-for="Email" class="form-control rounded-3" type="email" placeholder="you@example.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold">Password</label>
                    <input asp-for="Password" class="form-control rounded-3" type="password" placeholder="Enter password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold">Description</label>
                    <textarea asp-for="Description" class="form-control rounded-3" rows="4" placeholder="Describe your services"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-dark btn-lg rounded-3">Create Account</button>
                </div>
            </form>
        </div>

        <!-- Footer -->
        <div class="registration-footer bg-light text-center p-3 rounded-bottom-4">
            <small class="text-muted">
                Already have an account?
                <a asp-controller="Vendor" asp-action="Login" class="text-decoration-none fw-semibold">Login here</a>
            </small>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
