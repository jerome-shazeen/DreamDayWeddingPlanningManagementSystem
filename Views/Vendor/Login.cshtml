@model DreamDayWeddingPlanningManagementSystem.Models.LoginViewModel

@{
    ViewData["Title"] = "Couple Login";
    Layout = "_Layout";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <div class="card shadow-lg border-0 rounded-4" style="width: 100%; max-width: 500px;">
        <!-- Header -->
        <div class="card-header bg-dark text-white text-center rounded-top-4 py-4">
            <h2 class="mb-1 fw-bold">Couple Login</h2>
            <p class="mb-0 small text-light">Log in to your DreamDay account and manage your wedding plans</p>
        </div>

        <!-- Body -->
        <div class="card-body p-4 bg-white">
            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label for="EmailInput" class="form-label fw-semibold">Email Address</label>
                    <input id="EmailInput" name="Email" asp-for="Email" class="form-control rounded-3" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label for="PasswordInput" class="form-label fw-semibold">Password</label>
                    <input id="PasswordInput" name="Password" asp-for="Password" class="form-control rounded-3" type="password" placeholder="Enter your password" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-dark btn-lg rounded-3">Login</button>
                </div>
            </form>
        </div>

        <!-- Footer -->
        <div class="card-footer bg-light text-center rounded-bottom-4 py-3">
            <small class="text-muted">
                Don’t have an account?
                <a asp-controller="Account" asp-action="Register" class="fw-semibold text-decoration-none">Register here</a>
            </small>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
