@model IEnumerable<DreamDayWeddingPlanningManagementSystem.Models.Vendor>

@{
    ViewData["Title"] = "Vendor Catalog";
    Layout = "_Layout";
}

<div class="container py-5">
    <h2 class="fw-bold mb-4">🛍️ Vendor Catalog</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">No vendors available at the moment.</div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var vendor in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 rounded-4">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold">@vendor.Name</h5>
                            <p class="card-text text-muted flex-grow-1">@vendor.Description</p>
                            <p class="card-text mb-3">
                                <i class="bi bi-envelope"></i>
                                <small class="text-muted">@vendor.Email</small>
                            </p>
                            <a class="btn btn-outline-dark mt-auto rounded-pill" href="@Url.Action("Details", "Vendor", new { id = vendor.VendorId })">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
