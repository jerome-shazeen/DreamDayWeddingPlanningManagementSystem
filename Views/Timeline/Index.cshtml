@model IEnumerable<DreamDayWeddingPlanningManagementSystem.Models.TimelineEvent>

@{
    ViewData["Title"] = "Timeline Management";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold mb-0">📅 Timeline Events</h2>
                <a class="btn btn-dark rounded-pill" href="@Url.Action("Create", "Timeline")">+ Add Event</a>
            </div>

            <div class="table-responsive">
                <table class="table table-striped align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th scope="col">Event Name</th>
                            <th scope="col">Start Time</th>
                            <th scope="col">End Time</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var evt in Model)
                        {
                            <tr>
                                <td class="fw-medium">@evt.EventName</td>
                                <td>
                                    <span class="badge bg-primary">
                                        <i class="bi bi-clock"></i> @evt.StartTime.ToString("f")
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">
                                        <i class="bi bi-clock-history"></i> @evt.EndTime.ToString("f")
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
