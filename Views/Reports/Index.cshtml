@{
    ViewData["Title"] = "Reports & Analytics";
    Layout = "_Layout";
}

<div class="container py-5">
    <h2 class="fw-bold mb-4">📊 Reports & Analytics</h2>

    <!-- Summary Section -->
    <div class="row g-4 mb-5">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 text-center py-4">
                <div class="card-body">
                    <h5 class="fw-semibold mb-2">Total Weddings</h5>
                    <p class="display-4 fw-bold text-primary mb-0">@Model.TotalWeddings</p>
                </div>
            </div>
        </div>

        <!-- Placeholder Cards -->
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 text-center py-4">
                <div class="card-body">
                    <h5 class="fw-semibold mb-2">Most Popular Venue</h5>
                    <p class="text-muted">Coming Soon</p>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 text-center py-4">
                <div class="card-body">
                    <h5 class="fw-semibold mb-2">Average Budget</h5>
                    <p class="text-muted">Coming Soon</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Future Chart Area -->
    <div class="card shadow-sm border-0 rounded-4 p-4">
        <h5 class="fw-bold mb-3">Wedding Trends (Coming Soon)</h5>
        <div class="text-center text-muted py-5">
            <em>This section will show charts like weddings per month, budget trends, and popular categories.</em>
        </div>
    </div>
</div>
